<style is:global>
  .rp-subtitle {
    font-style: italic;
    color: var(--color-muted);
    font-size: 1.05rem;
    margin-top: -0.5rem;
    max-width: 36rem;
  }

  .rp-prose {
    max-width: 38rem;
    margin: 0 auto;
    font-family: 'Crimson Pro', var(--font-serif), Georgia, serif;
    font-size: 1.15rem;
    line-height: 1.85;
    color: var(--color-text);
  }

  .rp-prose p {
    margin: 1rem 0;
  }

  .rp-prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem auto;
    width: 40%;
  }

  .rp-prose em {
    font-style: italic;
  }

  /* verse blocks */
  .rp-verse {
    margin: 1.75rem 0;
    padding: 1.5rem 2rem;
    text-align: center;
    background: var(--color-surface);
    border-radius: 4px;
  }

  .rp-verse-sanskrit {
    font-size: 1.15rem;
    font-style: italic;
    line-height: 2;
    letter-spacing: 0.01em;
  }

  .rp-verse-highlight {
    border-left: 3px solid var(--color-accent);
    border-right: 3px solid var(--color-accent);
  }

  .rp-verse-highlight .rp-verse-sanskrit {
    font-size: 1.25rem;
    letter-spacing: 0.04em;
  }

  .rp-verse-split .rp-verse-sanskrit {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    letter-spacing: 0.06em;
    font-style: normal;
  }

  .rp-meaning {
    text-align: center;
    font-style: italic;
    color: var(--color-muted);
    font-size: 1rem;
    margin-top: -0.5rem;
  }

  /* the big number */
  .rp-number {
    text-align: center;
    margin: 2rem 0;
  }

  .rp-number-big {
    font-size: 3.5rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--color-text);
    display: block;
    line-height: 1;
  }

  /* pascal's triangle row */
  .rp-pascal {
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    padding: 1rem;
    margin: 1.25rem 0;
    background: var(--color-surface);
    border-radius: 4px;
    line-height: 1.8;
  }

  /* image slots — empty divs waiting for images */
  .rp-image-slot {
    margin: 2.5rem -2rem;
    min-height: 2px;
    /* images will go here via future edits */
  }

  /* coda */
  .rp-coda {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-text);
    margin: 2.5rem 0;
    letter-spacing: 0.02em;
  }

  /* closing link */
  .rp-closing {
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .rp-closing a {
    color: var(--color-accent);
  }

  /* responsive */
  @media (max-width: 640px) {
    .rp-prose {
      font-size: 1.05rem;
    }

    .rp-number-big {
      font-size: 2.5rem;
    }

    .rp-verse {
      padding: 1rem 1.25rem;
    }

    .rp-image-slot {
      margin: 2rem -1rem;
    }
  }
</style>
