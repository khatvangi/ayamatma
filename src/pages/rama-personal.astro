<tr><td>1</td><td>13</td><td>Two halves.</td></tr>
<tr><td>2</td><td>78</td><td></td></tr>
<tr><td>3</td><td>286</td><td></td></tr>
<tr><td>4</td><td>715</td><td></td></tr>
<tr><td>5</td><td>1,287</td><td></td></tr>
<tr><td>6</td><td><strong>1,716</strong></td><td>The tradition lives near here.</td></tr>
<tr><td>7</td><td><strong>1,716</strong></td><td>Twin peak. Maximum readings.</td></tr>
<tr><td>8</td><td>1,287</td><td></td></tr>
