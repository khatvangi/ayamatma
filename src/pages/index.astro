---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import DailyVerse from '../components/DailyVerse.astro';
import VideoCarousel from '../components/VideoCarousel.astro';
import { getCollection } from 'astro:content';
import videosData from '../data/videos.json';

const lang = 'en';
const base = '';

// get essay stats
const allEssays = await getCollection('essays');
const englishEssays = allEssays.filter(e => e.id.endsWith('.en.mdx'));
const essayCount = englishEssays.length;

// get recent essays (auto-sorted by date, newest first)
const recentEssays = englishEssays
  .filter(e => e.data.date) // ensure date exists
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3)
  .map(e => ({
    slug: e.id.replace('.en.mdx', ''),
    title: e.data.title,
    description: e.data.description,
    date: e.data.date,
    readingTime: e.data.reading_time,
  }));

// videos from data file
const askSwamiVideos = videosData.askSwami.videos.filter(v => v.id !== 'PLACEHOLDER');
---

<BaseLayout
  title="Ayamatma"
  description="A quiet space where Vedanta, rigorous science, and clear thinking meet."
  lang={lang}
  showSplash={true}
>

  <!-- hero -->
  <section class="hero">
    <div class="hero-visual">
      <img src="/images/red-tree.png" alt="" class="hero-image" />
    </div>
    <h1 class="sutra">अयमात्मा ब्रह्म</h1>
    <p class="sutra-translit">Ayam Ātmā Brahma</p>
    <p class="tagline">A quiet space where Vedānta, rigorous science, and clear thinking meet.</p>
  </section>

  <!-- intro text -->
  <section class="section">
    <div class="prose intro-text">
      <p>
        This site springs from the mahāvākya <em>Ayam Ātmā Brahma</em>—this very Ātman is Brahman.
        We explore Upaniṣadic Vedānta using the tools of science and philosophy: precise definitions,
        clear arguments, and honest dialogue.
      </p>
    </div>
  </section>

  <!-- two column: start here + stats -->
  <section class="section two-col">
    <a href={`${base}/essays/atman-not-soul`} class="start-here-card">
      <span class="badge">New to Vedānta?</span>
      <h3>Start with "Ātman is Not Soul"</h3>
      <p>Our most-read essay explaining why Western translations of "soul" and "self" miss what the Upaniṣads actually mean.</p>
      <span class="cta">Read Essay →</span>
    </a>
    <div class="stats-box">
      <div class="stat"><span class="stat-num">{essayCount}</span><span class="stat-label">Essays</span></div>
      <div class="stat"><span class="stat-num">1600+</span><span class="stat-label">Dictionary Terms</span></div>
      <div class="stat"><span class="stat-num">3</span><span class="stat-label">Languages</span></div>
      <div class="stat"><span class="stat-num">Daily</span><span class="stat-label">Gītā Verse</span></div>
    </div>
  </section>

  <!-- recent essays (auto-updated) -->
  <section class="section">
    <h2 class="section-title">Recent Essays</h2>
    <div class="recent-essays">
      {recentEssays.map(essay => (
        <a href={`${base}/essays/${essay.slug}`} class="essay-card">
          <span class="essay-date">{new Date(essay.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
          <h3>{essay.title}</h3>
          <p class="description">{essay.description}</p>
          <div class="meta">
            <span class="time">{essay.readingTime} min read</span>
          </div>
        </a>
      ))}
    </div>
    <a href={`${base}/essays`} class="view-all">View all {essayCount} essays →</a>
  </section>

  <!-- research -->
  <section class="section">
    <h2 class="section-title">Research</h2>
    <p class="section-desc">Computational analysis of sacred texts using the BORI Critical Edition</p>
    <div class="research-grid">
      <a href="/rama-nivedana.html" class="research-card">
        <span class="research-tag">Rāma Nivedana</span>
        <h3>What Hides Inside the Name We Chant</h3>
        <p>29 characters. 8,192 readings. Pascal's Triangle exact. Seven darśanas from one verse. The mouth reverses death with every repetition.</p>
        <span class="cta">Read →</span>
      </a>
      <a href="/ghana.html" class="research-card">
        <span class="research-tag">Ghanapāṭha</span>
        <h3>The Architecture of Sacred Sound</h3>
        <p>How Vedic reciters built an error-correcting code for sacred sound 3,000 years before Shannon. 16 words become 182 utterances of governed thunder.</p>
        <span class="cta">Read →</span>
      </a>
      <a href="/sahasra-infinite" class="research-card">
        <span class="research-tag">Sahasranāma</span>
        <h3>What If Sahasra Actually Means Infinite?</h3>
        <p>8,663 characters encode 10²'¹⁰³ possible readings — more than atoms in the universe. The title was not imprecise. We were reading it in the wrong register.</p>
        <span class="cta">Read →</span>
      </a>
      <a href="/vsn-1.html" class="research-card">
        <span class="research-tag">Vedic Roots</span>
        <h3>A Ṛk That Sings the Sāman</h3>
        <p>The Viṣṇu Sahasranāma as a smṛti text built with Vedic internal structure. Three registers — ṛk, sāman, yajus — seven Vedic metres, 24 Hari forms mapped against their ṛgvedic sources.</p>
        <span class="cta">Read →</span>
      </a>
      <a href="/vsn-2.html" class="research-card">
        <span class="research-tag">Structure</span>
        <h3>Why a Thousand Names, and Why in This Order</h3>
        <p>The Sahasranāma is not a list — it is a walk from the universe to the armed form. Three super-movements, seven arcs, the dharma quarantine, and the Vedic close.</p>
        <span class="cta">Read →</span>
      </a>
      <a href="/vsn-verse-14" class="research-card">
        <span class="research-tag">Verse 14</span>
        <h3>54.5 Billion Readings from 88 Characters</h3>
        <p>Seven curated readings of the Sahasranāma's opening verse. Each split produces a different darśana from the same Sanskrit.</p>
        <span class="cta">Read →</span>
      </a>
      <a href="/rama-8192" class="research-card">
        <span class="research-tag">Explorer</span>
        <h3>8,192 Readings — Complete Dataset</h3>
        <p>Every valid decomposition of the Rāma verse. Searchable, filterable, with Pascal's Triangle bar chart. Click any layer.</p>
        <span class="cta">Explore →</span>
      </a>
      <a href={`${base}/essays/sanjaya-criterion-of-recognition`} class="research-card">
        <span class="research-tag">Epistemology</span>
        <h3>The Criterion of Recognition</h3>
        <p>Sañjaya's Ātma Vidyā and the epistemology of Brahman-in-form. Why Sañjaya recognizes Krishna as Paramātman and Dhritarāṣṭra cannot.</p>
        <span class="cta">Read →</span>
      </a>
      <a href="/bhagavatpada.html" class="research-card">
        <span class="research-tag">Bhagavatpāda</span>
        <h3>Bhagavatpāda Deserves a Better Praise Than This</h3>
        <p>The śloka we recite each Jayantī calls him an abode of scripture. But he was not a repository — he was an argument.</p>
        <span class="cta">Read →</span>
      </a>
      <a href={`${base}/essays/syllable-as-mirror`} class="research-card">
        <span class="research-tag">Pramāṇa</span>
        <h3>The Syllable as Mirror</h3>
        <p>BU 5.2's Da-Da-Da passage reads as diagnostic before prescriptive. The same syllable lands differently on differently conditioned minds, and that difference is the teaching.</p>
        <span class="cta">Read →</span>
      </a>
    </div>
  </section>

  <!-- two column: explore + daily verse -->
  <section class="section two-col">
    <div class="explore-section">
      <h2 class="section-title">Explore</h2>
      <div class="explore-grid">
        <a href={`${base}/primer`} class="explore-item">
          <span class="explore-name">Primer</span>
          <span class="explore-desc">Core Vedāntic concepts explained</span>
        </a>
        <a href={`${base}/essays`} class="explore-item">
          <span class="explore-name">Essays</span>
          <span class="explore-desc">{essayCount} philosophical deep-dives</span>
        </a>
        <a href={`${base}/dictionary`} class="explore-item">
          <span class="explore-name">Dictionary</span>
          <span class="explore-desc">1600+ Sanskrit terms</span>
        </a>
        <a href={`${base}/science`} class="explore-item">
          <span class="explore-name">Science</span>
          <span class="explore-desc">Through a Vedāntic lens</span>
        </a>
        <a href={`${base}/manifesto`} class="explore-item">
          <span class="explore-name">Protocols</span>
          <span class="explore-desc">How we study with rigor</span>
        </a>
        <a href={`${base}/vada`} class="explore-item accent">
          <span class="explore-name">Vāda</span>
          <span class="explore-desc">Live philosophical dialogue</span>
        </a>
        <a href="/rama-nivedana.html" class="explore-item accent">
          <span class="explore-name">Rāma Nivedana</span>
          <span class="explore-desc">8,192 readings in 29 characters</span>
        </a>
        <a href="/ghana.html" class="explore-item accent">
          <span class="explore-name">Ghanapāṭha</span>
          <span class="explore-desc">The architecture of sacred sound</span>
        </a>
        <a href="/vsn-1.html" class="explore-item accent">
          <span class="explore-name">VSN: Vedic Roots</span>
          <span class="explore-desc">A ṛk that sings the sāman</span>
        </a>
        <a href="/vsn-2.html" class="explore-item accent">
          <span class="explore-name">VSN: Structure</span>
          <span class="explore-desc">Why a thousand names, in this order</span>
        </a>
        <a href="/bhagavatpada.html" class="explore-item accent">
          <span class="explore-name">Bhagavatpāda</span>
          <span class="explore-desc">Not a repository — an argument</span>
        </a>
        <a href={`${base}/essays/syllable-as-mirror`} class="explore-item accent">
          <span class="explore-name">Syllable as Mirror</span>
          <span class="explore-desc">BU 5.2 — what each defect hears</span>
        </a>
      </div>
    </div>
    <div class="daily-verse-wrapper">
      <DailyVerse lang={lang} />
    </div>
  </section>

  <!-- video carousel -->
  <section class="section">
    <VideoCarousel title="Ask Swami Sarvapriyananda" videos={askSwamiVideos} />
  </section>

  <!-- glimpses -->
  <section class="section">
    <h2 class="section-title">Glimpses</h2>
    <ImageCarousel />
  </section>

  <!-- footer quote -->
  <section class="section">
    <div class="quote-block">
      <p class="sanskrit">विद्या व्यये कृते वर्धते एव नित्यं।</p>
      <p class="english">Knowledge always grows when shared.</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* intro text */
  .intro-text {
    max-width: 720px;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  /* two column layout */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: stretch;
  }

  /* start here card */
  .start-here-card {
    display: flex;
    flex-direction: column;
    border: 2px solid var(--accent-warm);
    border-radius: 12px;
    padding: 1.5rem 2rem;
    text-decoration: none;
    background: var(--bg-card);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .start-here-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .start-here-card .badge {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-warm);
    margin-bottom: 0.5rem;
  }

  .start-here-card h3 {
    font-family: var(--font-display, 'Fraunces', serif);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.75rem 0;
    line-height: 1.3;
  }

  .start-here-card p {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  .start-here-card .cta {
    margin-top: 1rem;
    font-weight: 600;
    color: var(--accent-warm);
    font-size: 0.95rem;
  }

  /* stats box */
  .stats-box {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    background: var(--bg-card);
    border-radius: 12px;
    border: 1px solid var(--border);
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-num {
    font-family: var(--font-display, 'Fraunces', serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text);
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--muted);
  }

  /* recent essays */
  .recent-essays {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .essay-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color 200ms ease, transform 200ms ease;
  }

  .essay-card:hover {
    border-color: var(--accent-warm);
    transform: translateY(-2px);
  }

  .essay-card .essay-date {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-cool);
    margin-bottom: 0.5rem;
  }

  .essay-card h3 {
    font-family: var(--font-display, 'Fraunces', serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.75rem 0;
    line-height: 1.35;
  }

  .essay-card .description {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.55;
    margin: 0;
    flex-grow: 1;
  }

  .essay-card .meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .essay-card .time {
    color: var(--accent-warm);
    font-weight: 500;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.5rem;
    font-weight: 600;
    color: var(--accent-warm);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .view-all:hover {
    text-decoration: underline;
  }

  /* explore section */
  .explore-section {
    display: flex;
    flex-direction: column;
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .explore-item {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 200ms ease, background 200ms ease;
  }

  .explore-item:hover {
    border-color: var(--accent-warm);
    background: var(--bg-card);
  }

  .explore-item.accent {
    border-color: var(--accent-cool);
    background: rgba(90, 155, 143, 0.08);
  }

  .explore-item.accent:hover {
    background: rgba(90, 155, 143, 0.15);
  }

  /* research grid */
  .section-desc {
    color: var(--muted);
    font-size: 0.95rem;
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
  }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .research-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    background: var(--bg-card);
    transition: all 200ms;
  }

  .research-card:hover {
    border-color: var(--accent-warm);
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    transform: translateY(-2px);
  }

  .research-tag {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-cool);
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .research-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .research-card p {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0 0 0.75rem;
    flex: 1;
  }

  .research-card .cta {
    font-size: 0.82rem;
    color: var(--accent-warm);
    font-weight: 600;
  }

  .explore-name {
    font-weight: 600;
    font-size: 1rem;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .explore-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.4;
  }

  /* daily verse wrapper */
  .daily-verse-wrapper {
    display: flex;
    flex-direction: column;
  }

  /* responsive */
  @media (max-width: 900px) {
    .two-col {
      grid-template-columns: 1fr;
    }

    .recent-essays {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .explore-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .stats-box {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      padding: 1.25rem;
    }

    .explore-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
