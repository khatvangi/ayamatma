---
import BaseLayout from '../layouts/BaseLayout.astro';

const lang = 'en';
const pascal = [1,13,78,286,715,1287,1716,1716,1287,715,286,78,13,1];
---

<BaseLayout
  title="8,192 Readings of One Half-Verse"
  description="Every valid decomposition of śrīrāma rāmeti rāme rāme manorame. Pascal's Triangle, row 13, exact to every coefficient."
  lang={lang}
>
  <section class="section stack">
    <h1 class="section-title">8,192 Readings</h1>
    <p class="r8-subtitle">Every valid decomposition of <em>śrīrāma rāmeti rāme rāme manorame</em></p>
  </section>

  <section class="section">
    <div class="r8-container">

      <!-- the verse -->
      <div class="r8-verse">
        <div class="r8-verse-dev">श्रीरामरामेतिरामेरामेमनोरमे</div>
        <div class="r8-verse-iast">śrīrāmarāmetirāmerāmemanorame</div>
        <div class="r8-verse-meta">29 characters · 13 split points · 2<sup>13</sup> = 8,192 readings</div>
      </div>

      <!-- pascal distribution -->
      <div class="r8-pascal">
        <div class="r8-pascal-title">Pascal's Triangle — Row 13</div>
        <div class="r8-bars">
          {pascal.map((count, i) => {
            const segments = i + 1;
            const pct = (count / 1716) * 100;
            const label = segments === 1 ? 'pure vibration' :
                          segments === 7 ? 'tradition lives here' :
                          segments === 8 ? 'twin peak' :
                          segments === 14 ? 'every syllable · mantra' : '';
            return (
              <button class="r8-bar-row" data-segments={segments}>
                <span class="r8-bar-seg">{segments}</span>
                <span class="r8-bar-fill" style={`width: ${pct}%`}></span>
                <span class="r8-bar-count">{count.toLocaleString()}</span>
                {label && <span class="r8-bar-label">{label}</span>}
              </button>
            );
          })}
        </div>
        <div class="r8-pascal-footer">click any bar to filter · click again to show all</div>
      </div>

      <!-- search -->
      <div class="r8-controls">
        <input type="text" id="r8-search" class="r8-search" placeholder="search IAST, meaning, or binary id..." autocomplete="off" />
        <div class="r8-status" id="r8-status">loading 8,192 readings...</div>
      </div>

      <!-- readings table -->
      <div class="r8-table-wrap">
        <table class="r8-table" id="r8-table">
          <thead>
            <tr>
              <th class="r8-th-id">ID</th>
              <th class="r8-th-seg">#</th>
              <th class="r8-th-parts">Parts — Devanāgarī · IAST · meaning</th>
            </tr>
          </thead>
          <tbody id="r8-tbody"></tbody>
        </table>
      </div>

      <div class="r8-more" id="r8-more" style="display:none"></div>

    </div>
  </section>
</BaseLayout>

<style is:global>
  .r8-subtitle {
    font-style: italic;
    color: var(--color-muted);
    font-size: 1.05rem;
    margin-top: -0.5rem;
  }

  .r8-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  /* verse header */
  .r8-verse {
    text-align: center;
    padding: 1.5rem;
    margin-bottom: 1rem;
    background: var(--color-surface);
    border-radius: 8px;
  }

  .r8-verse-dev { font-size: 1.4rem; color: var(--color-text); letter-spacing: 0.02em; }
  .r8-verse-iast { font-size: 0.95rem; font-style: italic; color: var(--color-muted); margin-top: 0.4rem; }
  .r8-verse-meta { font-size: 0.78rem; color: var(--color-muted); margin-top: 0.5rem; }

  /* pascal bar chart */
  .r8-pascal {
    margin-bottom: 1rem;
    padding: 1.25rem;
    background: var(--color-text);
    border-radius: 8px;
    color: var(--color-bg);
  }

  .r8-pascal-title { font-size: 0.9rem; font-weight: 600; color: var(--color-accent); margin-bottom: 0.75rem; }

  .r8-bars { display: flex; flex-direction: column; gap: 2px; }

  .r8-bar-row {
    display: flex; align-items: center; gap: 0.4rem;
    background: none; border: none; color: var(--color-bg);
    cursor: pointer; padding: 1px 0; font-family: inherit; font-size: 0.75rem;
    text-align: left; width: 100%; border-radius: 2px; transition: background 120ms;
  }
  .r8-bar-row:hover { background: rgba(255,255,255,0.08); }
  .r8-bar-row.active { background: rgba(255,255,255,0.15); }

  .r8-bar-seg { width: 1.5rem; text-align: right; font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: rgba(255,255,255,0.5); flex-shrink: 0; }
  .r8-bar-fill { height: 14px; background: var(--color-accent); border-radius: 2px; min-width: 2px; }
  .r8-bar-count { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: rgba(255,255,255,0.6); flex-shrink: 0; min-width: 2.5rem; }
  .r8-bar-label { font-size: 0.65rem; font-style: italic; color: rgba(255,255,255,0.4); }
  .r8-pascal-footer { font-size: 0.68rem; color: rgba(255,255,255,0.3); margin-top: 0.5rem; text-align: center; }

  /* controls */
  .r8-controls { display: flex; gap: 0.75rem; align-items: center; margin-bottom: 0.75rem; flex-wrap: wrap; }
  .r8-search {
    flex: 1; min-width: 180px; padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border); border-radius: 6px;
    background: var(--color-bg); color: var(--color-text); font-size: 0.85rem; font-family: inherit;
  }
  .r8-search:focus { outline: none; border-color: var(--color-accent); }
  .r8-status { font-size: 0.75rem; color: var(--color-muted); white-space: nowrap; }

  /* table */
  .r8-table-wrap { overflow-x: auto; }

  .r8-table {
    width: 100%; border-collapse: collapse;
    font-size: 0.78rem; line-height: 1.35;
  }

  .r8-table thead th {
    background: var(--color-text); color: var(--color-bg);
    padding: 0.4rem 0.5rem; text-align: left;
    font-weight: 600; font-size: 0.68rem; letter-spacing: 0.04em;
    position: sticky; top: 0; z-index: 1;
  }

  .r8-th-id { width: 7rem; }
  .r8-th-seg { width: 2rem; text-align: center; }
  .r8-th-parts { }

  .r8-table tbody tr {
    border-bottom: 1px solid var(--color-border);
  }
  .r8-table tbody tr:nth-child(even) { background: var(--color-surface); }
  .r8-table tbody tr:hover { background: color-mix(in srgb, var(--color-accent) 8%, var(--color-bg)); }

  .r8-table td {
    padding: 0.3rem 0.5rem; vertical-align: top;
  }

  .r8-td-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--color-muted);
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .r8-td-seg {
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  .r8-meaning {
    font-size: 0.75rem;
    color: var(--color-text);
    margin-bottom: 0.3rem;
    line-height: 1.4;
    font-style: italic;
  }

  /* parts displayed inline */
  .r8-parts-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem 0.5rem;
  }

  .r8-part-chip {
    display: inline-flex;
    flex-direction: column;
    padding: 0.15rem 0;
    border-right: 1px solid var(--color-border);
    padding-right: 0.5rem;
  }

  .r8-part-chip:last-child {
    border-right: none;
    padding-right: 0;
  }

  .r8-pc-dev {
    font-size: 0.85rem;
    color: var(--color-text);
  }

  .r8-pc-iast {
    font-size: 0.68rem;
    font-style: italic;
    color: var(--color-muted);
  }

  .r8-pc-meaning {
    font-size: 0.65rem;
    color: var(--color-muted);
    max-width: 14rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .r8-more {
    text-align: center; padding: 0.75rem;
    color: var(--color-muted); font-size: 0.82rem;
    cursor: pointer; border-radius: 6px;
  }
  .r8-more:hover { color: var(--color-accent); background: var(--color-surface); }

  @media (max-width: 768px) {
    .r8-container { max-width: 100%; }
    .r8-verse-dev { font-size: 1rem; }
    .r8-th-id { width: 5rem; }
    .r8-td-id { font-size: 0.58rem; }
    .r8-pc-dev { font-size: 0.78rem; }
    .r8-part-chip { padding-right: 0.35rem; }
  }
</style>

<script is:inline>
(function() {
  var data = null;
  var filtered = null;
  var activeSegment = null;
  var page = 0;
  var PAGE_SIZE = 100;

  fetch('/data/rama_8192.json')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      data = d;
      filtered = d;
      document.getElementById('r8-status').textContent = '8,192 readings loaded';
      renderPage(0);
    })
    .catch(function() {
      document.getElementById('r8-status').textContent = 'failed to load data';
    });

  // bar clicks
  document.querySelectorAll('.r8-bar-row').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var seg = parseInt(this.dataset.segments);
      if (activeSegment === seg) {
        activeSegment = null;
        this.classList.remove('active');
      } else {
        document.querySelectorAll('.r8-bar-row').forEach(function(b) { b.classList.remove('active'); });
        activeSegment = seg;
        this.classList.add('active');
      }
      applyFilter();
    });
  });

  // search
  var searchEl = document.getElementById('r8-search');
  var searchTimer = null;
  searchEl.addEventListener('input', function() {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(applyFilter, 200);
  });

  function applyFilter() {
    if (!data) return;
    var q = searchEl.value.toLowerCase().trim();
    filtered = data.filter(function(entry) {
      if (activeSegment && entry.segments !== activeSegment) return false;
      if (!q) return true;
      if (entry.id.indexOf(q) !== -1) return true;
      if (entry.iast.toLowerCase().indexOf(q) !== -1) return true;
      if (entry.dev.indexOf(q) !== -1) return true;
      if (entry.meaning && entry.meaning.toLowerCase().indexOf(q) !== -1) return true;
      for (var i = 0; i < entry.parts.length; i++) {
        if (entry.parts[i].iast && entry.parts[i].iast.toLowerCase().indexOf(q) !== -1) return true;
      }
      return false;
    });
    page = 0;
    document.getElementById('r8-status').textContent = filtered.length.toLocaleString() + ' of 8,192';
    renderPage(0);
  }

  function renderPage(p) {
    var tbody = document.getElementById('r8-tbody');
    var moreEl = document.getElementById('r8-more');
    if (p === 0) tbody.innerHTML = '';

    var start = p * PAGE_SIZE;
    var end = Math.min(start + PAGE_SIZE, filtered.length);
    var html = '';

    for (var i = start; i < end; i++) {
      var e = filtered[i];
      html += '<tr>';
      html += '<td class="r8-td-id">' + e.id + '</td>';
      html += '<td class="r8-td-seg">' + e.segments + '</td>';
      html += '<td>';
      // composite meaning line
      if (e.meaning) html += '<div class="r8-meaning">' + e.meaning + '</div>';
      // parts chips
      html += '<div class="r8-parts-row">';
      for (var j = 0; j < e.parts.length; j++) {
        var pt = e.parts[j];
        html += '<div class="r8-part-chip">';
        html += '<span class="r8-pc-dev">' + pt.dev + '</span>';
        html += '<span class="r8-pc-iast">' + pt.iast + '</span>';
        html += '</div>';
      }
      html += '</div></td></tr>';
    }

    if (p === 0) {
      tbody.innerHTML = html;
    } else {
      tbody.insertAdjacentHTML('beforeend', html);
    }

    // show more button
    if (end < filtered.length) {
      moreEl.textContent = 'show more (' + (filtered.length - end).toLocaleString() + ' remaining)';
      moreEl.style.display = 'block';
    } else {
      moreEl.style.display = 'none';
    }
  }

  // "show more" click
  document.getElementById('r8-more').addEventListener('click', function() {
    page++;
    renderPage(page);
  });
})();
</script>
